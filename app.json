{
  "expo": {
    "name": "BizRecord",
    "slug": "booker-inventory",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#031f38"
    },
    "platforms": [
      "ios",
      "android"
    ],
    "scheme": "bizrecord",
    "sdkVersion": "49.0.0",
    "runtimeVersion": "1.0.0",
    "updates": {
      "fallbackToCacheOnError": true
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.bookerapp.inventory",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#031f38"
      },
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "useNextNotificationFormat": true
    },
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.bookerapp.inventory",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is used to capture inventory photos",
        "UIRequiredDeviceCapabilities": [
          "armv7"
        ]
      },
      "associatedDomains": []
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "description": "Inventory management app for managing stock, tracking transactions, and generating reports",
    "privacy": "https://example.com/privacy",
    "primaryColor": "#00A676",
    "androidStatusBar": {
      "backgroundColor": "#031f38",
      "barStyle": "light-content"
    },
    "backgroundColor": "#ffffff",
    "plugins": [],
    "extra": {
      "apiUrl": "https://bizrecord-kk4y2.ondigitalocean.app",
      "eas": {
        "projectId": "595d2e24-df5b-4d3b-b308-7c45a082711b"
      }
    }
  }
}
