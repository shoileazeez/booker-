{
  "expo": {
    "name": "BizRecord",
    "slug": "bizrecord",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "cli": {
      "watchman": false
    },
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#031f38"
    },
    "platforms": [
      "ios",
      "android"
    ],
    "scheme": "bizrecord",
    "runtimeVersion": "1.0.0",
    "updates": {
      "fallbackToCacheOnError": true
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "package": "com.bizrecord.inventory",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#031f38"
      },
      "permissions": [
        "com.android.vending.BILLING",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "useNextNotificationFormat": true
    },
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.bizrecord.inventory",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is used to capture inventory photos",
        "UIRequiredDeviceCapabilities": [
          "armv7"
        ]
      },
      "associatedDomains": []
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "description": "Inventory management app for managing stock, tracking transactions, and generating reports",
    "privacy": "https://bizrecord.tech/privacy",
    "primaryColor": "#00A676",
    "androidStatusBar": {
      "backgroundColor": "#031f38",
      "barStyle": "light-content"
    },
    "backgroundColor": "#ffffff",
    "plugins": [
      "expo-notifications",
      "react-native-iap",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.2.0"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "b5fa460b-4c59-483e-9a97-9d4936e35f49"
      }
    },
    "owner": "bizrecord-organization"
  }
}
