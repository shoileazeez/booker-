{
  "name": "booker-ui",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "start:win": "set EXPO_NO_DEPENDENCY_VALIDATION=1&& set CHOKIDAR_USEPOLLING=1&& set WATCHPACK_POLLING=true&& expo start -c",
    "dev:android": "expo start --android",
    "dev:ios": "expo start --ios",
    "dev:web": "expo start --web",
    "test:local": "expo start",
    "build:apk": "eas build --platform android --profile development",
    "build:ipa": "eas build --platform ios --profile production",
    "build:ipa-sim": "eas build --platform ios --profile preview",
    "build:aab-android": "eas build --platform android --profile production",
    "build:aab-ios": "eas build --platform ios --profile production",
    "build:playstore": "eas build --platform android --profile production",
    "build:appstore": "eas build --platform ios --profile production",
    "build:preview": "eas build --platform all --profile preview",
    "submit:playstore": "eas submit --platform android --latest",
    "submit:appstore": "eas submit --platform ios --latest"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-picker/picker": "2.11.1",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@types/pdfkit": "^0.17.5",
    "aws-sdk": "^2.1693.0",
    "expo": "~54.0.33",
    "expo-build-properties": "~1.0.9",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.16",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-local-authentication": "~17.0.8",
    "expo-notifications": "~0.32.16",
    "expo-sharing": "~14.0.8",
    "expo-sqlite": "~16.0.10",
    "pdfkit": "^0.18.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-iap": "^14.7.0",
    "react-native-nitro-modules": "^0.35.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "eas-cli": "^18.4.0"
  }
}
